{
  "name": "@oni.bot/stores",
  "version": "0.1.0",
  "description": "Persistent KV store backends (Redis, Postgres) for @oni.bot/core agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*"
  ],
  "peerDependencies": {
    "@oni.bot/core": "^1.3.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@oni.bot/core": "workspace:*",
    "typescript": "^5.4.0",
    "vite": "8.0.12",
    "vitest": "^4.1.6"
  },
  "license": "MIT"
}
