{
  "name": "@oni.bot/devtools",
  "version": "0.1.0",
  "description": "Lightweight dev server for inspecting ONI graph topology, registry state, and live execution events",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "peerDependencies": {
    "@oni.bot/core": "^1.3.0"
  },
  "devDependencies": {
    "@oni.bot/core": "workspace:*",
    "typescript": "^5.4.0",
    "vite": "8.0.12",
    "vitest": "^4.1.6"
  },
  "license": "MIT"
}
